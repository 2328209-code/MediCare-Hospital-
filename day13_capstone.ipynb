    "# ── Build ChromaDB Collection ──\n",
    "import chromadb\n",
    "from sentence_transformers import SentenceTransformer\n",
    "\n",
    "embedder = SentenceTransformer('all-MiniLM-L6-v2')\n",
    "print('✅ Embedder loaded.')\n",
    "\n",
    "chroma_client = chromadb.Client()\n",
    "collection = chroma_client.create_collection(name='medicare_kb')\n",
    "\n",
    "docs_text = [doc['text'] for doc in KNOWLEDGE_BASE]\n",
    "docs_ids  = [doc['id']   for doc in KNOWLEDGE_BASE]\n",
    "docs_meta = [{'topic': doc['topic']} for doc in KNOWLEDGE_BASE]\n",
    "docs_embs = embedder.encode(docs_text).tolist()\n",
    "\n",
    "collection.add(documents=docs_text, embeddings=docs_embs, ids=docs_ids, metadatas=docs_meta)\n",
    "print(f'✅ ChromaDB collection built with {collection.count()} documents.')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
